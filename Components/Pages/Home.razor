@page "/"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Rotary Club of Lugbe VON — Attendance & Birthdays</PageTitle>

<div class="dashboard" id="dashboard">
    <section class="welcome">
        <div>
            <p class="overline live-clock">@_currentTime.ToString("dddd, d MMMM yyyy").ToUpperInvariant() · @_currentTime.ToString("h:mm:ss tt") WAT</p>
            <h1>Good evening, VON Lugbe Rotarians.</h1>
            <p>Here’s what’s happening in your club this month.</p>
        </div>
        <button class="primary-action" @onclick="OpenCheckIn"><span>＋</span> Mark attendance</button>
    </section>

    <section class="club-identity-card" aria-label="Rotary Club identity and contacts">
        <img src="rotary-logo.jpeg" alt="Rotary Club of Abuja Lugbe VON logo" />
        <div class="club-identity-copy">
            <span class="overline">ROTARY CLUB OF ABUJA LUGBE VON</span>
            <h2>Club contact RTN: Femi</h2>
            <p>Call the club contact directly for enquiries and fellowship information.</p>
        </div>
        <div class="club-phone-links">
            <a href="tel:+2348038046707"><small>MAIN CONTACT · RTN. FEMI</small><b>0803 804 6707</b></a>
            <a href="tel:+2348020336898"><small>ALTERNATE NUMBER</small><b>0802 033 6898</b></a>
        </div>
    </section>

    <section class="visitor-rtn-card" id="visitor-rtn">
        <div>
            <span class="overline">VISITING ROTARIANS</span>
            <h2>Visiting RTN? You are welcome here.</h2>
            <p>Register your visit or contact RTN. Femi before fellowship.</p>
        </div>
        <div class="visitor-rtn-links">
            <button @onclick="OpenVisitorCheckIn">Register as visiting RTN</button>
            <a href="tel:+2348038046707">Call RTN. Femi</a>
            <a class="visitor-whatsapp" href="https://wa.me/2348038046707?text=Hello%20RTN.%20Femi%2C%20I%20am%20a%20visiting%20Rotarian." target="_blank" rel="noopener">WhatsApp RTN. Femi</a>
        </div>
    </section>

    <section class="rotary-year-banner">
        <img src="new-rotary-year.jpeg" alt="Happy New Rotary Year" />
        <div>
            <span class="overline">A NEW YEAR OF SERVICE</span>
            <h2>Happy New Rotary Year!</h2>
            <p>Here’s to another year of fellowship, service above self, and lasting impact with the Rotary Club of Abuja Lugbe VON.</p>
        </div>
        <span class="banner-year">2026<br /><small>2027</small></span>
    </section>

    <section class="metrics">
        <article>
            <span class="metric-icon blue">♙</span>
            <div><small>Total members</small><strong>@Members.Count</strong><p>Registered Rotarians</p></div>
            <i>↗</i>
        </article>
        <article>
            <span class="metric-icon gold">✓</span>
            <div><small>Last meeting</small><strong>@PresentCount</strong><p>of @Members.Count members present</p></div>
            <i>↗</i>
        </article>
        <article>
            <span class="metric-icon green">◔</span>
            <div><small>Attendance rate</small><strong>@AttendanceRate%</strong><p><b>+4.2%</b> from last month</p></div>
            <i>↗</i>
        </article>
        <article>
            <span class="metric-icon coral">♢</span>
            <div><small>July birthdays</small><strong>6</strong><p><b>2</b> coming up this week</p></div>
            <i>↗</i>
        </article>
    </section>

    <section class="meeting-link-card">
        <div class="meeting-date-box"><b>05</b><span>JUL</span></div>
        <div class="meeting-link-copy">
            <span class="overline">ROTARY CLUB OF ABUJA LUGBE VON</span>
            <h2>Monthly Club Fellowship</h2>
            <p>Biweekly (twice a month) · 3:30 PM for 4:00 PM · 10PM Lounge, VON</p>
        </div>
        <button class="invitation-button" @onclick="OpenInvitation"><span>▧</span> View invitation</button>
    </section>

    <section class="club-contact-card" id="club-details" aria-label="Club fellowship details">
        <div><small>Venue</small><b>10PM Lounge, VON</b></div>
        <div><small>Fellowship schedule</small><b>Biweekly (twice a month)</b></div>
        <div><small>Time</small><b>3:30 PM for 4:00 PM</b></div>
        <div><small>Club contact person</small><b>RTN. Femi: 08038046707 / 08020336898</b></div>
    </section>

    <section class="bank-share-card">
        <div class="bank-icon">₦</div>
        <div class="bank-details">
            <span class="overline">ROTARY CLUB OF LUGBE VON ACCOUNT</span>
            <b>Account No: 1015520143</b>
            <label>Bank
                <input placeholder="Enter bank name" @bind="_bankName" @bind:event="oninput" />
            </label>
        </div>
        @if (string.IsNullOrWhiteSpace(_bankName))
        {
            <button class="whatsapp-share disabled" disabled>Enter bank name first</button>
        }
        else
        {
            <a class="whatsapp-share" href="@WhatsAppShareUrl" target="_blank" rel="noopener">
                <span>◉</span> Share to WhatsApp
            </a>
        }
    </section>

    <section class="dashboard-grid">
        <div class="panel attendance-panel" id="attendance">
            <div class="panel-heading">
                <div><h2>Recent attendance</h2><p>Thursday fellowship · 2 July 2026</p></div>
                <div class="panel-actions">
                    <div class="table-search"><span>⌕</span><input placeholder="Find member" @bind="_query" @bind:event="oninput" /></div>
                    <a class="outline-btn" href="attendance-register.csv" download>Export</a>
                </div>
            </div>
            <div class="attendance-summary">
                <div class="progress-ring"><span>@AttendanceRate<small>%</small></span></div>
                <div><b>Strong turnout</b><p>@PresentCount members checked in for the last fellowship.</p></div>
                <div class="legend"><span><i class="present-dot"></i> Present @PresentCount</span><span><i class="absent-dot"></i> Absent @AbsentCount</span></div>
            </div>
            <div class="table-wrap" id="members">
                <table>
                    <thead><tr><th>Member</th><th>Classification</th><th>Check-in</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var member in FilteredMembers)
                        {
                            <tr>
                                <td><div class="member"><span style="background:@member.Color">@member.Initials</span><div><b>@member.Name</b><small>@member.Id</small></div></div></td>
                                <td>@member.Classification</td>
                                <td>@member.CheckIn</td>
                                <td><button class="status @(member.Present ? "present" : "absent")" @onclick="() => ToggleAttendance(member)"><i></i>@(member.Present ? "Present" : "Absent")</button></td>
                                <td><button class="more" title="View member details" @onclick="() => ShowMember(member.Name)">•••</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <a class="view-all" href="#members">View full attendance register <span>→</span></a>
        </div>

        <aside class="panel birthday-panel" id="birthdays">
            <div class="panel-heading">
                <div><h2>Upcoming birthdays</h2><p>Celebrate our Rotarians</p></div>
                <a class="calendar-button" href="#birthdays" aria-label="Open birthdays">▦</a>
            </div>
            <div class="birthday-hero">
                <span class="confetti one">✦</span><span class="confetti two">•</span><span class="confetti three">◆</span>
                <div class="birthday-avatar">CN</div>
                <small>NEXT BIRTHDAY · IN 2 DAYS</small>
                <h3>Chidi Nwosu</h3>
                <p>Monday, 6 July</p>
                <button @onclick="SendChidiWish">Send birthday wish</button>
            </div>
            <div class="birthday-list">
                @foreach (var birthday in Birthdays)
                {
                    <article>
                        <div class="date-tile"><b>@birthday.Day</b><small>JUL</small></div>
                        <div><b>@birthday.Name</b><small>@birthday.Role</small></div>
                        <button @onclick="() => SendWish(birthday.Name)" title="Send birthday wish">✉</button>
                    </article>
                }
            </div>
            <a class="view-all" href="#birthdays">View all birthdays <span>→</span></a>
        </aside>
    </section>

    <section class="monthly panel">
        <div class="panel-heading"><div><h2>Monthly attendance trend</h2><p>Rotary year 2026/27</p></div><span class="trend-up">↗ 8.4% growth</span></div>
        <div class="bar-chart">
            @foreach (var point in Trend)
            {
                <div><span style="height:@($"{point.Value}%")"><i>@point.Value%</i></span><small>@point.Month</small></div>
            }
        </div>
    </section>

    <section class="newsletter-panel" id="newsletter">
        <div class="newsletter-copy">
            <span class="overline">CLUB NEWSLETTER</span>
            <h2>Rotary Lugbe VON News &amp; Updates</h2>
            <p>Watch club announcements, fellowship highlights, service projects, and messages from club leadership.</p>
            <span class="newsletter-status">Next video newsletter coming soon</span>
        </div>
        <div class="newsletter-video-placeholder" aria-label="Newsletter video coming soon">
            <span>▶</span>
            <b>Video newsletter</b>
            <small>Your club video will appear here</small>
        </div>
    </section>
</div>

@if (_showCheckIn)
{
    <div class="modal-backdrop">
        <section class="checkin-modal">
            <header><div><span>✓</span><div><h2>Mark attendance</h2><p>Thursday fellowship · 9 July 2026</p></div></div><button @onclick="CloseCheckIn">×</button></header>
            <label>Member name
                <select @bind="_selectedMember">
                    <option value="">Select a member</option>
                    @foreach (var member in Members) { <option value="@member.Name">@member.Name</option> }
                </select>
            </label>
            <label>Attendance status
                <div class="status-options">
                    <button class="@(_checkInStatus == "Present" ? "selected" : "")" @onclick="SetPresent"><i class="present-dot"></i>Present</button>
                    <button class="@(_checkInStatus == "Absent" ? "selected" : "")" @onclick="SetAbsent"><i class="absent-dot"></i>Absent</button>
                </div>
            </label>
            @if (!string.IsNullOrEmpty(_notice)) { <p class="modal-notice">@_notice</p> }
            <button class="save-button" @onclick="SaveCheckIn">Save attendance</button>
        </section>
    </div>
}

@if (_showVisitorCheckIn)
{
    <div class="modal-backdrop">
        <section class="checkin-modal">
            <header><div><span>VR</span><div><h2>Visiting Rotarian registration</h2><p>Welcome to Rotary Club of Abuja Lugbe VON</p></div></div><button @onclick="CloseVisitorCheckIn">×</button></header>
            <label>Full name
                <input placeholder="Enter your full name" @bind="_visitorName" />
            </label>
            <label>Rotary club
                <input placeholder="Enter your home club" @bind="_visitorClub" />
            </label>
            <label>Phone number
                <input type="tel" placeholder="Enter your phone number" @bind="_visitorPhone" />
            </label>
            @if (!string.IsNullOrEmpty(_visitorNotice)) { <p class="modal-notice">@_visitorNotice</p> }
            <button class="save-button" @onclick="SaveVisitorCheckIn">Register visit</button>
        </section>
    </div>
}

@if (!string.IsNullOrEmpty(_toast))
{
    <div class="toast"><span>✓</span>@_toast</div>
}

@if (_showInvitation)
{
    <div class="invitation-backdrop" @onclick="CloseInvitation">
        <section class="invitation-modal" @onclick:stopPropagation>
            <header><div><b>Handover Ceremony &amp; Fellowship</b><small>Sunday, 5 July 2026</small></div><button @onclick="CloseInvitation">×</button></header>
            <img src="rotary-handover-july-5.jpeg" alt="Rotary Club of Abuja Lugbe VON handover ceremony invitation" />
        </section>
    </div>
}

@code {
    private string _query = "";
    private bool _showCheckIn;
    private string _selectedMember = "";
    private string _checkInStatus = "Present";
    private string _notice = "";
    private string _toast = "";
    private bool _showInvitation;
    private string _bankName = "";
    private bool _showVisitorCheckIn;
    private string _visitorName = "";
    private string _visitorClub = "";
    private string _visitorPhone = "";
    private string _visitorNotice = "";
    private DateTime _currentTime = GetLagosTime();
    private Timer? _clockTimer;

    private readonly List<Member> Members =
    [
        new("Akinkuehinmi Segun", "RY-1001", "Rotarian", "AS", "#D9E7FB", "—", false),
        new("Hafsah Balogun Omotoso", "RY-1002", "Rotarian", "HBO", "#FBE2D5", "—", false),
        new("Agbogunleye Femi", "RY-1003", "Fashion Designing", "AF", "#E2ECD7", "—", false),
        new("Adesanya Sunkanmi", "RY-1004", "Rotarian", "AS", "#EEE2FA", "—", false),
        new("Ibiso Ohiagba", "RY-1005", "Rotarian", "IO", "#F7E9C9", "—", false),
        new("Adekunle Sonukan", "RY-1006", "Franchise Merchandising", "AS", "#D9E7FB", "—", false),
        new("Festus Etaze", "RY-1007", "Rotarian", "FE", "#FBE2D5", "—", false),
        new("Pankshak Haggai", "RY-1008", "Rotarian", "PH", "#E2ECD7", "—", false),
        new("Amadi Okechukwu", "RY-1009", "Rotarian", "AO", "#EEE2FA", "—", false),
        new("Prince Chukwuma Onyenankeya", "RY-1010", "Rotarian", "PCO", "#F7E9C9", "—", false),
        new("Akinola Macarthy", "RY-1011", "Rotarian", "AM", "#D9E7FB", "—", false),
        new("Alphonsus Ajugwe", "RY-1012", "Rotarian", "AA", "#FBE2D5", "—", false),
        new("Isah Emmanuel Idris", "RY-1013", "Rotarian", "IEI", "#E2ECD7", "—", false),
        new("Olatunji Aransiola", "RY-1014", "Rotarian", "OA", "#EEE2FA", "—", false),
        new("Agnes Ikechi-Oleka", "RY-1015", "Rotarian", "AIO", "#F7E9C9", "—", false),
        new("Sunday Job", "RY-1016", "Rotarian", "SJ", "#D9E7FB", "—", false),
        new("Akinyemi Anderson", "RY-1017", "Rotarian", "AA", "#FBE2D5", "—", false),
        new("Ahmed Badejo", "RY-1018", "Rotarian", "AB", "#E2ECD7", "—", false),
        new("Bidemi Adeyemo", "RY-1019", "Rotarian", "BA", "#EEE2FA", "—", false),
        new("Olusola Ogundele", "RY-1020", "Rotarian", "OO", "#F7E9C9", "—", false),
        new("Celestine Opurum", "RY-1021", "Rotarian", "CO", "#D9E7FB", "—", false),
        new("Udeh Chijioke", "RY-1022", "Rotarian", "UC", "#FBE2D5", "—", false),
        new("Adegoke Bamidele", "RY-1023", "Rotarian", "AB", "#E2ECD7", "—", false),
        new("Ndaguda Nelly", "RY-1024", "Rotarian", "NN", "#EEE2FA", "—", false),
        new("Jane Ejikeme", "RY-1025", "Rotarian", "JE", "#F7E9C9", "—", false)
    ];
    private readonly List<Birthday> Birthdays =
    [
        new("09", "Oluchi Eke", "Club Treasurer"),
        new("14", "Emeka Ibe", "Past President"),
        new("21", "Aisha Lawal", "Rotarian"),
        new("28", "Bode Martins", "Service Chair")
    ];
    private readonly List<TrendPoint> Trend =
    [
        new("Feb", 58), new("Mar", 66), new("Apr", 62), new("May", 75), new("Jun", 71), new("Jul", 79)
    ];

    private IEnumerable<Member> FilteredMembers => Members.Where(m => $"{m.Name} {m.Classification} {m.Id}".Contains(_query, StringComparison.OrdinalIgnoreCase));
    protected override void OnInitialized()
    {
        _clockTimer = new Timer(_ =>
        {
            _currentTime = GetLagosTime();
            _ = InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }
    private static DateTime GetLagosTime()
    {
        try
        {
            var zone = TimeZoneInfo.FindSystemTimeZoneById(OperatingSystem.IsWindows()
                ? "W. Central Africa Standard Time"
                : "Africa/Lagos");
            return TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, zone);
        }
        catch (TimeZoneNotFoundException)
        {
            return DateTime.UtcNow.AddHours(1);
        }
    }
    public void Dispose() => _clockTimer?.Dispose();
    private string WhatsAppShareUrl
    {
        get
        {
            var message = $"Rotary Club of Lugbe VON Account Details:\nAccount No: 1015520143\nBank: {_bankName.Trim()}";
            return $"https://wa.me/?text={Uri.EscapeDataString(message)}";
        }
    }
    private int PresentCount => Members.Count(m => m.Present);
    private int AbsentCount => Members.Count - PresentCount;
    private int AttendanceRate => Members.Count == 0 ? 0 : (int)Math.Round(PresentCount / (double)Members.Count * 100);
    private void ToggleAttendance(Member member) => member.Present = !member.Present;
    private void OpenCheckIn() { _showCheckIn = true; _notice = ""; }
    private void CloseCheckIn() => _showCheckIn = false;
    private void SetPresent() => _checkInStatus = "Present";
    private void SetAbsent() => _checkInStatus = "Absent";
    private void OpenInvitation() => _showInvitation = true;
    private void CloseInvitation() => _showInvitation = false;
    private void OpenVisitorCheckIn() { _showVisitorCheckIn = true; _visitorNotice = ""; }
    private void CloseVisitorCheckIn() => _showVisitorCheckIn = false;
    private Task SendChidiWish() => SendWish("Chidi Nwosu");
    private async Task ShowMember(string name)
    {
        _toast = $"Member selected: {name}.";
        await Task.Delay(2800);
        _toast = "";
    }
    private async Task SaveVisitorCheckIn()
    {
        if (string.IsNullOrWhiteSpace(_visitorName) || string.IsNullOrWhiteSpace(_visitorClub))
        {
            _visitorNotice = "Please enter your name and Rotary club.";
            return;
        }

        _showVisitorCheckIn = false;
        _toast = $"Welcome, RTN. {_visitorName}. Your visit has been registered.";
        _visitorName = "";
        _visitorClub = "";
        _visitorPhone = "";
        await Task.Delay(2800);
        _toast = "";
    }
    private async Task SaveCheckIn()
    {
        if (string.IsNullOrEmpty(_selectedMember)) { _notice = "Please select a member."; return; }
        var member = Members.First(m => m.Name == _selectedMember);
        member.Present = _checkInStatus == "Present";
        member.CheckIn = member.Present ? DateTime.Now.ToString("h:mm tt") : "—";
        _showCheckIn = false;
        _toast = $"Attendance saved for {_selectedMember}.";
        await Task.Delay(2800);
        _toast = "";
    }
    private async Task SendWish(string name)
    {
        _toast = $"Birthday wish prepared for {name}.";
        await Task.Delay(2800);
        _toast = "";
    }
    private sealed class Member(string name, string id, string classification, string initials, string color, string checkIn, bool present)
    {
        public string Name { get; } = name; public string Id { get; } = id; public string Classification { get; } = classification;
        public string Initials { get; } = initials; public string Color { get; } = color; public string CheckIn { get; set; } = checkIn; public bool Present { get; set; } = present;
    }
    private sealed record Birthday(string Day, string Name, string Role);
    private sealed record TrendPoint(string Month, int Value);
}
