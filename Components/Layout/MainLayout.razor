@inherits LayoutComponentBase

<div class="app-shell">
    @if (_menuOpen)
    {
        <button class="nav-scrim" @onclick="ToggleMenu" aria-label="Close navigation"></button>
    }
    <aside class="@(_menuOpen ? "sidebar open" : "sidebar")">
        <div class="brand">
            <img class="brand-logo" src="rotary-logo.jpeg" alt="Rotary Club of Abuja Lugbe VON" />
            <span class="rotary-wheel">✦</span>
            <div><b>Rotary</b><small>Lugbe VON</small></div>
        </div>
        <div class="club-card">
            <span>RC</span>
            <div><b>Rotary Club of Lugbe VON</b><small>Abuja · Nigeria</small></div>
        </div>
        <nav>
            <span class="nav-label">CLUB MANAGEMENT</span>
            <a href="#dashboard" class="active"><i>⌂</i> Overview</a>
            <a href="#attendance"><i>✓</i> Attendance</a>
            <a href="#birthdays"><i>♢</i> Birthdays</a>
            <span class="nav-label lower">ACCOUNT</span>
            <a href="#members"><i>♙</i> Members</a>
            <a href="#club-details"><i>⚙</i> Club details</a>
        </nav>
        <div class="side-profile">
            <span>VR</span>
            <div><b>VON Lugbe Rotarians</b><small>Club Account</small></div>
            <a class="sign-out" href="/club-logout" title="Sign out">↪</a>
        </div>
    </aside>
    <main class="main-area">
        <header class="topbar">
            <button class="mobile-menu" @onclick="ToggleMenu" aria-label="Open navigation">☰</button>
            <div class="top-search"><span>⌕</span><input placeholder="Search members..." /></div>
            <div class="top-actions">
                <span class="meeting-date">Fellowship: <b>Biweekly · 3:30 PM for 4:00 PM</b></span>
                <a class="bell" href="#birthdays" aria-label="Birthday notifications">♢<i></i></a>
                <div class="mini-avatar">VR</div>
            </div>
        </header>
        @Body
    </main>
</div>

@code {
    private bool _menuOpen;
    private void ToggleMenu() => _menuOpen = !_menuOpen;
}
